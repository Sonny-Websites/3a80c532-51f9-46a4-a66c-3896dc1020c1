---
interface Props {
  current?: 'home' | 'about' | 'thank-you';
}

const { current } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '') || '';
---

<header class="topbar" role="banner">
  <div class="container topbar-inner">
    <a href={base + '/'} class="logo-text">TradePath</a>
    <nav class="top-nav" role="navigation" aria-label="Main navigation">
      <a href={base + '/'} aria-current={current === 'home' ? 'page' : undefined}>Home</a>
      <a href={base + '/about/'} aria-current={current === 'about' ? 'page' : undefined}>About</a>
      <a href={base + '/#how-it-works'}>How it works</a>
      <a href={base + '/#sign-up'}>Contact/Sign up</a>
    </nav>
  </div>
</header>
