---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Coming Soon"
  description="Simple, fast landing pages to announce your project and collect interest."
  ogTitle="Coming soon"
  ogDescription="We help busy teams launch faster."
>
  <main>
    <header class="topbar" role="banner">
      <div class="container topbar-inner">
        <div class="logo-text">Logo Placeholder</div>
        <a href="#contact" class="btn-outline">Contact</a>
      </div>
    </header>

    <section class="hero" role="region" aria-labelledby="heroHeading">
      <div class="container hero-inner">
        <h1 id="heroHeading">Coming soon — we’ll be here shortly.</h1>
        <p>We help busy teams launch faster.</p>
        <a href="#contact" class="btn-solid">Contact us</a>
      </div>
    </section>

    <section class="blurb" role="region" aria-labelledby="aboutHeading">
      <div class="container">
        <h2 id="aboutHeading">About</h2>
        <p>Simple, fast landing pages to announce your project and collect interest. No code required.</p>
      </div>
    </section>

    <section id="features" class="features" role="region" aria-labelledby="featuresHeading">
      <div class="container">
        <h2 id="featuresHeading">Highlights</h2>
        <div class="features-grid">
          <article class="feature-card">
            <h3>Collect leads</h3>
            <p>Simple contact forms for requests and signups.</p>
          </article>
          <article class="feature-card">
            <h3>Share info</h3>
            <p>Show your services, hours, and links in one place.</p>
          </article>
          <article class="feature-card">
            <h3>Launch quickly</h3>
            <p>Get a live page in minutes and iterate later.</p>
          </article>
        </div>
      </div>
    </section>

    <section id="contact" class="contact" role="region" aria-labelledby="contactHeading">
      <div class="container">
        <h2 id="contactHeading">Contact us</h2>
        <p class="contact-copy">Tell us a bit about your request and we’ll follow up by email.</p>

        <form id="contactForm" method="post" action="/__forms/contact" novalidate>
          <div class="form-group">
            <label for="name">Name <span aria-label="required">*</span></label>
            <input type="text" id="name" name="name" required aria-required="true" aria-describedby="nameError" />
            <span id="nameError" class="error-message"></span>
          </div>

          <div class="form-group">
            <label for="email">Email <span aria-label="required">*</span></label>
            <input type="email" id="email" name="email" required aria-required="true" aria-describedby="emailError" />
            <span id="emailError" class="error-message"></span>
          </div>

          <div class="form-group">
            <label for="phone">Phone (optional)</label>
            <input type="tel" id="phone" name="phone" />
          </div>

          <div class="form-group">
            <label for="message">Message <span aria-label="required">*</span></label>
            <textarea id="message" name="message" rows="5" required aria-required="true" aria-describedby="messageError"></textarea>
            <span id="messageError" class="error-message"></span>
          </div>

          <input type="text" name="_hp" style="display:none" autocomplete="off" tabindex="-1" />
          <button type="submit" id="submitBtn" class="btn-solid" aria-busy="false">Submit</button>
        </form>

        <div id="responseMessage" role="alert" aria-live="polite"></div>
      </div>
    </section>

    <footer class="site-footer">
      <div class="container footer-inner">
        <p>Powered by Pluzi — simple landing pages.</p>
        <nav aria-label="Footer links">
          <a href="#">Privacy</a>
          <a href="#">Terms</a>
        </nav>
      </div>
    </footer>
  </main>
</BaseLayout>
