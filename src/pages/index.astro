---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="TradePath — Connect to work opportunities"
  description="TradePath connects unemployed adults and students to paid opportunities nationwide."
  ogTitle="TradePath — Connect to work opportunities"
  ogDescription="Connecting unemployed adults and students to paid opportunities — nationwide."
>
  <main>
    <header class="topbar" role="banner">
      <div class="container topbar-inner">
        <a href="#home" class="logo-text">TradePath</a>
        <nav class="top-nav" aria-label="Primary">
          <a href="#home">Home</a>
          <a href="#about">About</a>
          <a href="#how-it-works">How it works</a>
          <a href="#sign-up">Contact/Sign up</a>
        </nav>
      </div>
    </header>

    <section id="home" class="hero" role="region" aria-labelledby="heroHeading">
      <div class="container hero-inner">
        <h1 id="heroHeading">Find work. Earn income. Build a life.</h1>
        <h2>Connecting unemployed adults and students to paid opportunities — nationwide.</h2>
        <a href="#sign-up" class="btn-solid">Sign up</a>

        <form class="signup-form" data-signup-form method="post" action="/__forms/contact" novalidate>
          <div class="form-group">
            <label for="hero-name">Name <span aria-label="required">*</span></label>
            <input type="text" id="hero-name" name="name" required aria-required="true" />
            <span class="error-message" data-error-for="name"></span>
          </div>

          <div class="form-group">
            <label for="hero-email">Email <span aria-label="required">*</span></label>
            <input type="email" id="hero-email" name="email" required aria-required="true" />
            <span class="error-message" data-error-for="email"></span>
          </div>

          <input type="text" name="_hp" style="display:none" autocomplete="off" tabindex="-1" />
          <button type="submit" class="btn-solid submit-btn" aria-busy="false">Sign up</button>
          <small class="response-message" role="status" aria-live="polite"></small>
        </form>
      </div>
    </section>

    <section id="about" class="blurb" role="region" aria-labelledby="aboutHeading">
      <div class="container">
        <h2 id="aboutHeading">Opportunities for students and unemployed adults</h2>
        <p>TradePath helps people discover paid jobs, short-term gigs, and income-building opportunities across the country.</p>
      </div>
    </section>

    <section id="how-it-works" class="features" role="region" aria-labelledby="featuresHeading">
      <div class="container">
        <h2 id="featuresHeading">How it works</h2>
        <div class="features-grid">
          <article class="feature-card">
            <h3>1. Sign up</h3>
            <p>Share your name and email to join the opportunities list.</p>
          </article>
          <article class="feature-card">
            <h3>2. Get matched</h3>
            <p>Receive opportunities that align with your availability and interests.</p>
          </article>
          <article class="feature-card">
            <h3>3. Start earning</h3>
            <p>Apply quickly and begin paid work opportunities in your area.</p>
          </article>
        </div>
      </div>
    </section>

    <section id="sign-up" class="contact" role="region" aria-labelledby="contactHeading">
      <div class="container">
        <h2 id="contactHeading">Contact/Sign up</h2>
        <p class="contact-copy">Join TradePath and we will follow up by email with next steps.</p>

        <form id="contactForm" class="signup-form" data-signup-form method="post" action="/__forms/contact" novalidate>
          <div class="form-group">
            <label for="contact-name">Name <span aria-label="required">*</span></label>
            <input type="text" id="contact-name" name="name" required aria-required="true" />
            <span class="error-message" data-error-for="name"></span>
          </div>

          <div class="form-group">
            <label for="contact-email">Email <span aria-label="required">*</span></label>
            <input type="email" id="contact-email" name="email" required aria-required="true" />
            <span class="error-message" data-error-for="email"></span>
          </div>

          <input type="text" name="_hp" style="display:none" autocomplete="off" tabindex="-1" />
          <button type="submit" class="btn-solid submit-btn" aria-busy="false">Sign up</button>
          <small class="response-message" role="status" aria-live="polite"></small>
        </form>
      </div>
    </section>

    <footer class="site-footer">
      <div class="container footer-inner">
        <small>&copy; <span id="year">2026</span> TradePath</small>
        <small>Connect to work opportunities nationwide.</small>
      </div>
    </footer>
  </main>
</BaseLayout>
