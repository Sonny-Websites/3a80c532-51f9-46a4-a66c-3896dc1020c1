---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '') || '';
---

<BaseLayout
  title="TradePath — Connect to work opportunities"
  description="Learn about TradePath and how we connect students and unemployed adults to paid opportunities."
  ogTitle="TradePath — Connect to work opportunities"
  ogDescription="Learn how TradePath helps connect people to paid opportunities nationwide."
>
  <Header current="about" />
  <section class="about" role="main" aria-labelledby="aboutHeading">
    <div class="container">
      <h1 id="aboutHeading">About TradePath</h1>
      <p>TradePath connects unemployed adults and students to paid opportunities across the country.</p>
      <p>Our goal is simple: make it easier to find work, earn income, and build long-term stability.</p>
      <a href={`${base}/#sign-up`} class="btn-solid" style="display: inline-flex; margin-top: 24px;">Sign up</a>
    </div>
  </section>
  <Footer />
</BaseLayout>
