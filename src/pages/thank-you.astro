---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '') || '';
---

<BaseLayout
  title="TradePath — Connect to work opportunities"
  description="Thank you for signing up with TradePath."
  ogTitle="TradePath — Connect to work opportunities"
  ogDescription="Thank you for signing up with TradePath."
>
  <section class="thank-you" role="main" aria-labelledby="thankHeading">
    <h1 id="thankHeading">Thank you</h1>
    <p>Thanks — we received your signup. We’ll be in touch.</p>
    <a href={base + '/'} class="btn-solid" style="margin-top: 24px;">Back to home</a>
  </section>
</BaseLayout>
