---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '') || '';
---

<BaseLayout
  title="Thank You"
  description="Thank you for contacting us. We have received your message."
  ogTitle="Thank you"
  ogDescription="Your message has been received."
>
  <section class="thank-you" role="main" aria-labelledby="thankHeading">
    <h1 id="thankHeading">Thank you</h1>
    <p>Your message has been sent successfully.</p>
    <p>We will follow up soon.</p>
    <a href={base + '/'} class="btn-solid" style="margin-top: 24px;">Back to home</a>
  </section>
</BaseLayout>
